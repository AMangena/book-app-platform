<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        body { font-family: system-ui, sans-serif; background: #f4f4f7; padding: 2rem; }
        .container { max-width: 720px; margin: 0 auto; background: #fff; padding: 2rem; border-radius: 12px; box-shadow: 0 2px 10px rgba(0,0,0,.06); }
        h1 { color: #1a1a2e; }
        .env { color: #6b7280; }
        table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
        th, td { text-align: left; padding: .7rem; border-bottom: 1px solid #eee; }
        th { background: #f0f0f3; }
    </style>
</head>
<body>@RenderBody()</body>
</html>
